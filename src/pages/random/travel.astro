---
import RandomLayout from "~/layouts/RandomLayout.astro";

const lived = [
    { city: "Dallas-Fort Worth", label: "dfw, tx", lat: 32.7767, lng: -96.797, kind: "lived" },
    { city: "Houston", label: "houston, tx", lat: 29.7604, lng: -95.3698, kind: "lived" },
    { city: "Grand Prairie", label: "grand prairie, tx", lat: 32.7459, lng: -96.998, kind: "lived" },
    { city: "New York City", label: "nyc · yahoo ibp", lat: 40.7128, lng: -74.006, kind: "lived" },
    { city: "Plano", label: "plano · jpmc c4g", lat: 33.0198, lng: -96.6989, kind: "lived" },
    { city: "San Francisco", label: "sf · snap summer '26", lat: 37.7749, lng: -122.4194, kind: "lived" },
];
const wishlist = [
    { city: "Tokyo", label: "tokyo", lat: 35.6762, lng: 139.6503, kind: "wishlist" },
    { city: "Seoul", label: "seoul", lat: 37.5665, lng: 126.978, kind: "wishlist" },
    { city: "Lisbon", label: "lisbon", lat: 38.7223, lng: -9.1393, kind: "wishlist" },
    { city: "London", label: "london", lat: 51.5074, lng: -0.1278, kind: "wishlist" },
    { city: "Kyoto", label: "kyoto", lat: 35.0116, lng: 135.7681, kind: "wishlist" },
    { city: "Lagos", label: "lagos", lat: 6.5244, lng: 3.3792, kind: "wishlist" },
];
const allPoints = [...lived, ...wishlist];

// Blank placeholder tiles. Swap `caption` with real city names and drop
// matching images at `public/assets/travel/<slug>.jpg` when ready, then
// set the `img` field per tile to show the photo.
const photos = [
    { caption: "houston, tx" },
    { caption: "dallas-fort worth" },
    { caption: "nyc" },
    { caption: "plano, tx" },
    { caption: "san francisco" },
    { caption: "tokyo" },
    { caption: "seoul" },
    { caption: "lisbon" },
    { caption: "london" },
    { caption: "kyoto" },
    { caption: "lagos" },
];
---

<RandomLayout
    slug="travel"
    title="Jordan Otomu · random / travel"
    description="Cities Jordan's lived, worked, and wants to visit."
>
    <div class="globe-wrap">
        <div class="globe-stage" id="globe" aria-hidden="true"></div>

        <div class="globe-hud">
            <div>travel.exe</div>
            <div>drag to rotate</div>
            <div>wheel or pinch to zoom</div>
        </div>

        <div class="globe-legend">
            <div class="legend-row">
                <span class="legend-mark">
                    <svg viewBox="0 0 20 20" width="14" height="14" aria-hidden="true">
                        <rect x="1" y="1" width="18" height="18" fill="#22c55e" stroke="#1a1a1a" stroke-width="1.5" rx="2"/>
                        <path d="M5 10 L9 14 L15 6" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span>been there</span>
            </div>
            <div class="legend-row">
                <span class="legend-mark">
                    <svg viewBox="0 0 20 28" width="11" height="16" aria-hidden="true">
                        <path d="M10 0.8C4.9 0.8 1 4.5 1 9.5C1 16.8 10 27 10 27C10 27 19 16.8 19 9.5C19 4.5 15.1 0.8 10 0.8Z"
                            fill="#e55" stroke="#1a1a1a" stroke-width="1.4"/>
                        <circle cx="10" cy="9.5" r="2.6" fill="#1a1a1a"/>
                    </svg>
                </span>
                <span>bucket list</span>
            </div>
        </div>
    </div>

    <div class="photo-scroll" aria-label="travel photos">
        <div class="photo-marquee">
            {photos.map((p) => (
                <figure class="photo-card">
                    <div class="photo-thumb" aria-hidden="true"></div>
                    <figcaption class="photo-caption">{p.caption}</figcaption>
                </figure>
            ))}
            {/* duplicate for seamless infinite scroll */}
            {photos.map((p) => (
                <figure class="photo-card" aria-hidden="true">
                    <div class="photo-thumb" aria-hidden="true"></div>
                    <figcaption class="photo-caption">{p.caption}</figcaption>
                </figure>
            ))}
        </div>
    </div>

    <p class="note">
        TODO: share your list of cities and i'll pin them. drop photos into
        <code>public/assets/travel/</code> and i'll wire them into the carousel.
    </p>
</RandomLayout>

<script is:inline define:vars={{ allPoints }}>
    window.__travelPoints = allPoints;
</script>

<script>
    import Globe from "globe.gl";

    async function mountGlobe() {
        const el = document.getElementById("globe");
        if (!el) return;

        const allPoints = (window as any).__travelPoints || [];

        const countries = await fetch("/assets/data/countries.geojson")
            .then((r) => (r.ok ? r.json() : { features: [] }))
            .catch(() => ({ features: [] }));

        // Andrew-style: always a light cream globe with soft gray continents
        // and a faint graticule grid, regardless of dark/light mode.
        const GLOBE_CREAM = 0xeeeae0;
        const LAND_FILL = "rgba(26, 26, 26, 0.12)";
        const LAND_SIDE = "rgba(26, 26, 26, 0.04)";
        const LAND_STROKE = "rgba(26, 26, 26, 0.45)";
        const ATMOSPHERE = "#bbb";

        const size = () => {
            const w = el.clientWidth || 600;
            const h = Math.min(440, Math.max(320, w * 0.6));
            return { w, h };
        };
        let { w, h } = size();

        const pinSvg = (kind: string) => {
            if (kind === "wishlist") {
                return `<svg viewBox="0 0 20 28" width="22" height="30"><path d="M10 0.8C4.9 0.8 1 4.5 1 9.5C1 16.8 10 27 10 27C10 27 19 16.8 19 9.5C19 4.5 15.1 0.8 10 0.8Z" fill="#e55" stroke="#1a1a1a" stroke-width="1.4"/><circle cx="10" cy="9.5" r="2.8" fill="#1a1a1a"/></svg>`;
            }
            return `<svg viewBox="0 0 20 20" width="22" height="22"><rect x="1" y="1" width="18" height="18" fill="#22c55e" stroke="#1a1a1a" stroke-width="1.5" rx="2"/><path d="M5 10 L9 14 L15 6" stroke="white" stroke-width="2.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        };

        const globe = new Globe(el, { animateIn: true })
            .backgroundColor("rgba(0,0,0,0)")
            .showGlobe(true)
            .showGraticules(true)
            .showAtmosphere(true)
            .atmosphereColor(ATMOSPHERE)
            .atmosphereAltitude(0.15)
            .globeImageUrl(null as any)
            .polygonsData((countries as any).features || [])
            .polygonAltitude(0.004)
            .polygonCapColor(() => LAND_FILL)
            .polygonSideColor(() => LAND_SIDE)
            .polygonStrokeColor(() => LAND_STROKE)
            .htmlElementsData(allPoints)
            .htmlLat("lat")
            .htmlLng("lng")
            .htmlAltitude(0.005)
            .htmlElement((d: any) => {
                const div = document.createElement("div");
                div.innerHTML = pinSvg(d.kind);
                div.style.cursor = "pointer";
                div.style.pointerEvents = "auto";
                div.style.transform =
                    d.kind === "wishlist"
                        ? "translate(-50%, -100%)"
                        : "translate(-50%, -50%)";
                div.title = `${d.city} — ${d.kind === "wishlist" ? "bucket list" : "been there"}`;
                div.addEventListener("click", () => {
                    globe.pointOfView({ lat: d.lat, lng: d.lng, altitude: 1.4 }, 900);
                });
                return div;
            })
            .width(w)
            .height(h);

        const mat: any = globe.globeMaterial();
        if (mat?.color?.set) mat.color.set(GLOBE_CREAM);
        if (mat) {
            mat.opacity = 1;
            mat.transparent = false;
        }

        const controls: any = globe.controls();
        controls.autoRotate = false;
        controls.enableZoom = true;
        controls.minDistance = 220;
        controls.maxDistance = 800;
        controls.rotateSpeed = 0.6;

        globe.pointOfView({ lat: 25, lng: -40, altitude: 2.4 }, 0);

        const onResize = () => {
            const next = size();
            w = next.w;
            h = next.h;
            globe.width(w).height(h);
        };
        window.addEventListener("resize", onResize);
        if ("ResizeObserver" in window) {
            const ro = new ResizeObserver(onResize);
            ro.observe(el);
        }
    }

    if (document.readyState !== "loading") mountGlobe();
    else document.addEventListener("DOMContentLoaded", mountGlobe);
</script>

<style>
    /* ---------- globe container ---------- */
    .globe-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: auto;
        border: 1px solid var(--faint);
        margin: 4px 0 14px;
        background:
            linear-gradient(
                135deg,
                rgba(26, 26, 26, 0.02),
                transparent 60%
            ),
            var(--bg);
        background-image:
            linear-gradient(0deg, var(--faint) 1px, transparent 1px),
            linear-gradient(90deg, var(--faint) 1px, transparent 1px);
        background-size: 28px 28px, 28px 28px;
        overflow: hidden;
    }
    .globe-stage {
        width: 100%;
        display: block;
    }
    :global(.globe-stage canvas) {
        display: block;
        margin: 0 auto;
        max-width: 100%;
    }

    /* ---------- hud + legend ---------- */
    .globe-hud,
    .globe-legend {
        position: absolute;
        padding: 7px 10px;
        background: var(--bg);
        border: 1px solid var(--border);
        font-family: var(--font-mono);
        font-size: 11.5px;
        line-height: 1.45;
        color: var(--ink);
        pointer-events: none;
        z-index: 3;
    }
    .globe-hud { top: 12px; left: 12px; }
    .globe-legend {
        bottom: 12px;
        left: 12px;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    .legend-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .legend-mark {
        width: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* ---------- marquee carousel ---------- */
    .photo-scroll {
        overflow: hidden;
        border: 1px solid var(--faint);
        padding: 14px 0;
        background: var(--bg);
        margin: 14px 0;
        position: relative;
    }
    .photo-scroll::before,
    .photo-scroll::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 40px;
        z-index: 2;
        pointer-events: none;
    }
    .photo-scroll::before {
        left: 0;
        background: linear-gradient(to right, var(--bg), transparent);
    }
    .photo-scroll::after {
        right: 0;
        background: linear-gradient(to left, var(--bg), transparent);
    }

    .photo-marquee {
        display: flex;
        gap: 12px;
        width: max-content;
        animation: marquee 55s linear infinite;
        padding: 0 12px;
    }
    .photo-scroll:hover .photo-marquee { animation-play-state: paused; }

    @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
    }

    .photo-card {
        flex: 0 0 180px;
        border: 1px solid var(--border);
        background: var(--bg);
        overflow: hidden;
    }
    .photo-thumb {
        width: 100%;
        aspect-ratio: 1 / 1;
        background-color: var(--faint);
        background-image:
            repeating-linear-gradient(
                45deg,
                rgba(26, 26, 26, 0.06) 0 8px,
                transparent 8px 16px
            );
        border-bottom: 1px solid var(--faint);
    }
    .photo-caption {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--ink);
        padding: 7px 10px;
    }

    @media (max-width: 720px) {
        .globe-hud, .globe-legend {
            font-size: 10.5px;
            padding: 6px 8px;
        }
        .photo-card { flex-basis: 148px; }
    }

    @media (prefers-reduced-motion: reduce) {
        .photo-marquee { animation: none; }
    }
</style>

---
import RandomLayout from "~/layouts/RandomLayout.astro";

// places i've spent meaningful time — core homes / repeat trips plus a
// sweep of east-coast and international cities.
const lived = [
    { city: "Houston, TX", lat: 29.7604, lng: -95.3698, kind: "lived" },
    { city: "Washington, DC", lat: 38.9072, lng: -77.0369, kind: "lived" },
    { city: "New York City, NY", lat: 40.7128, lng: -74.006, kind: "lived" },
    { city: "Nairobi, Kenya", lat: -1.2921, lng: 36.8219, kind: "lived" },
    { city: "Dubai, UAE", lat: 25.2048, lng: 55.2708, kind: "lived" },
    { city: "Amsterdam, NL", lat: 52.3676, lng: 4.9041, kind: "lived" },
    { city: "Boston, MA", lat: 42.3601, lng: -71.0589, kind: "lived" },
    { city: "Philadelphia, PA", lat: 39.9526, lng: -75.1652, kind: "lived" },
    { city: "Baltimore, MD", lat: 39.2904, lng: -76.6122, kind: "lived" },
    { city: "Charlotte, NC", lat: 35.2271, lng: -80.8431, kind: "lived" },
    { city: "Atlanta, GA", lat: 33.7490, lng: -84.3880, kind: "lived" },
    { city: "Miami, FL", lat: 25.7617, lng: -80.1918, kind: "lived" },
];

// bucket-list trips, all picked for scenery: aurora country, colonial
// hill town, alpine lakes, north-atlantic cliffs, fairy-chimney valley.
const wishlist = [
    { city: "Lapland, Finland", lat: 67.9222, lng: 26.5046, kind: "wishlist" },
    { city: "Antigua, Guatemala", lat: 14.5586, lng: -90.7339, kind: "wishlist" },
    { city: "Banff, Canada", lat: 51.4968, lng: -115.9281, kind: "wishlist" },
    { city: "Faroe Islands", lat: 62.0, lng: -6.7833, kind: "wishlist" },
    { city: "Cappadocia, Turkey", lat: 38.6431, lng: 34.8289, kind: "wishlist" },
];
const allPoints = [...lived, ...wishlist];

// travel photos with captions. files live in public/assets/travel/ —
// numbered 01-15. captions are best-guess based on what's visible in
// each shot; edit any that are wrong.
const photos = [
    { src: "/assets/travel/01.png", caption: "houston, tx" },
    { src: "/assets/travel/02.png", caption: "washington, dc" },
    { src: "/assets/travel/03.png", caption: "plano, tx" },
    { src: "/assets/travel/04.png", caption: "plano, tx" },
    { src: "/assets/travel/05.png", caption: "new york city" },
    { src: "/assets/travel/06.png", caption: "new york city" },
    { src: "/assets/travel/07.png", caption: "washington, dc" },
    { src: "/assets/travel/08.png", caption: "dallas-fort worth" },
    { src: "/assets/travel/09.png", caption: "plano, tx" },
    { src: "/assets/travel/10.png", caption: "washington, dc" },
    { src: "/assets/travel/11.png", caption: "washington, dc" },
    { src: "/assets/travel/12.png", caption: "houston, tx" },
    { src: "/assets/travel/13.png", caption: "nairobi, kenya" },
    { src: "/assets/travel/14.png", caption: "houston, tx" },
    { src: "/assets/travel/15.png", caption: "on the road" },
];
---

<RandomLayout
    slug="travel"
    title="Jordan Otomu · random / travel"
    description="Cities Jordan's lived, worked, and wants to visit."
>
    <div class="globe-wrap">
        <div class="globe-stage" id="globe" aria-hidden="true"></div>

        <div class="globe-hud">
            <div>travel.exe</div>
            <div>drag to rotate</div>
            <div>wheel or pinch to zoom</div>
        </div>

        <div class="globe-legend">
            <div class="legend-row">
                <span class="legend-mark">
                    <svg viewBox="0 0 20 20" width="14" height="14" aria-hidden="true">
                        <rect x="1" y="1" width="18" height="18" fill="#22c55e" stroke="#1a1a1a" stroke-width="1.5" rx="2"/>
                        <path d="M5 10 L9 14 L15 6" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span>been there</span>
            </div>
            <div class="legend-row">
                <span class="legend-mark">
                    <svg viewBox="0 0 20 28" width="11" height="16" aria-hidden="true">
                        <path d="M10 0.8C4.9 0.8 1 4.5 1 9.5C1 16.8 10 27 10 27C10 27 19 16.8 19 9.5C19 4.5 15.1 0.8 10 0.8Z"
                            fill="#e55" stroke="#1a1a1a" stroke-width="1.4"/>
                        <circle cx="10" cy="9.5" r="2.6" fill="#1a1a1a"/>
                    </svg>
                </span>
                <span>bucket list</span>
            </div>
        </div>
    </div>

    <div class="photo-scroll" aria-label="travel photos">
        <div class="photo-marquee">
            {photos.map((p) => (
                <figure class="photo-card">
                    <div class="photo-frame">
                        <img class="photo-img" src={p.src} alt={p.caption} loading="lazy" />
                    </div>
                    <figcaption class="photo-caption">{p.caption}</figcaption>
                </figure>
            ))}
            {/* duplicate for seamless infinite scroll */}
            {photos.map((p) => (
                <figure class="photo-card" aria-hidden="true">
                    <div class="photo-frame">
                        <img class="photo-img" src={p.src} alt="" loading="lazy" />
                    </div>
                    <figcaption class="photo-caption">{p.caption}</figcaption>
                </figure>
            ))}
        </div>
    </div>
</RandomLayout>

<script is:inline define:vars={{ allPoints }}>
    window.__travelPoints = allPoints;
</script>

<script>
    import Globe from "globe.gl";

    async function mountGlobe() {
        const el = document.getElementById("globe");
        if (!el) return;

        const allPoints = (window as any).__travelPoints || [];

        const countries = await fetch("/assets/data/countries.geojson")
            .then((r) => (r.ok ? r.json() : { features: [] }))
            .catch(() => ({ features: [] }));

        // Andrew-style light globe (same look in dark + light mode).
        // Cream sphere, soft-gray continent fills + dark outlines, faint
        // graticule grid, subtle gray atmosphere.
        const GLOBE_COLOR = 0xdedbce;
        const LAND_CAP = "rgba(26, 26, 26, 0.35)";
        const LAND_SIDE = "rgba(26, 26, 26, 0.12)";
        const LAND_STROKE = "rgba(26, 26, 26, 0.75)";
        const ATMOSPHERE = "#9a9a9a";

        const size = () => {
            const w = el.clientWidth || 600;
            const h = Math.min(420, Math.max(300, Math.round(w * 0.55)));
            return { w, h };
        };
        let { w, h } = size();

        const pinSvg = (kind: string) => {
            if (kind === "wishlist") {
                return `<svg viewBox="0 0 20 28" width="22" height="30"><path d="M10 0.8C4.9 0.8 1 4.5 1 9.5C1 16.8 10 27 10 27C10 27 19 16.8 19 9.5C19 4.5 15.1 0.8 10 0.8Z" fill="#e55" stroke="#1a1a1a" stroke-width="1.4"/><circle cx="10" cy="9.5" r="2.8" fill="#1a1a1a"/></svg>`;
            }
            return `<svg viewBox="0 0 20 20" width="22" height="22"><rect x="1" y="1" width="18" height="18" fill="#22c55e" stroke="#1a1a1a" stroke-width="1.5" rx="2"/><path d="M5 10 L9 14 L15 6" stroke="white" stroke-width="2.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        };

        const globe = new Globe(el, { animateIn: true })
            .backgroundColor("rgba(0,0,0,0)")
            .showGlobe(true)
            .showGraticules(true)
            .showAtmosphere(true)
            .atmosphereColor(ATMOSPHERE)
            .atmosphereAltitude(0.18)
            .polygonsData((countries as any).features || [])
            .polygonAltitude(0.006)
            .polygonCapColor(() => LAND_CAP)
            .polygonSideColor(() => LAND_SIDE)
            .polygonStrokeColor(() => LAND_STROKE)
            .htmlElementsData(allPoints)
            .htmlLat("lat")
            .htmlLng("lng")
            .htmlAltitude(0.005)
            .htmlElement((d: any) => {
                const div = document.createElement("div");
                div.innerHTML = pinSvg(d.kind);
                div.style.cursor = "pointer";
                div.style.pointerEvents = "auto";
                div.style.transform =
                    d.kind === "wishlist"
                        ? "translate(-50%, -100%)"
                        : "translate(-50%, -50%)";
                div.title = `${d.city} — ${d.kind === "wishlist" ? "bucket list" : "been there"}`;
                div.addEventListener("click", () => {
                    globe.pointOfView({ lat: d.lat, lng: d.lng, altitude: 1.4 }, 900);
                });
                return div;
            })
            .width(w)
            .height(h);

        // Override the globe texture with a flat cream color so the sphere
        // reads against the cream page background via its atmosphere + polygons.
        const mat: any = globe.globeMaterial();
        if (mat?.color?.set) mat.color.set(GLOBE_COLOR);
        if (mat) {
            mat.opacity = 1;
            mat.transparent = false;
            if ("needsUpdate" in mat) mat.needsUpdate = true;
        }

        const controls: any = globe.controls();
        controls.autoRotate = false;
        controls.enableZoom = true;
        controls.minDistance = 220;
        controls.maxDistance = 800;
        controls.rotateSpeed = 0.6;

        globe.pointOfView({ lat: 25, lng: -30, altitude: 2.5 }, 0);

        const onResize = () => {
            const next = size();
            w = next.w;
            h = next.h;
            globe.width(w).height(h);
        };
        window.addEventListener("resize", onResize);
        if ("ResizeObserver" in window) {
            const ro = new ResizeObserver(onResize);
            ro.observe(el);
        }
    }

    if (document.readyState !== "loading") mountGlobe();
    else document.addEventListener("DOMContentLoaded", mountGlobe);
</script>

<style>
    .globe-wrap {
        position: relative;
        width: 100%;
        max-width: 720px;
        margin: 4px auto 18px;
        background: var(--bg);
        overflow: hidden;
    }
    .globe-stage {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    :global(.globe-stage canvas) {
        display: block;
        margin: 0 auto;
        max-width: 100%;
    }

    .globe-hud,
    .globe-legend {
        position: absolute;
        padding: 7px 10px;
        background: var(--bg);
        border: 1px solid var(--border);
        font-family: var(--font-mono);
        font-size: 11.5px;
        line-height: 1.45;
        color: var(--ink);
        pointer-events: none;
        z-index: 3;
    }
    .globe-hud { top: 12px; left: 12px; }
    .globe-legend {
        bottom: 12px;
        left: 12px;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    .legend-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .legend-mark {
        width: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .photo-scroll {
        overflow: hidden;
        padding: 22px 0 6px;
        background: transparent;
        margin: 18px 0 0;
        position: relative;
        /* keep the marquee child clipped to the parent's width instead of
           letting `width: max-content` push the carousel past the fieldset. */
        width: 100%;
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
    }
    .photo-scroll::before,
    .photo-scroll::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 48px;
        z-index: 2;
        pointer-events: none;
    }
    .photo-scroll::before {
        left: 0;
        background: linear-gradient(to right, var(--bg), transparent);
    }
    .photo-scroll::after {
        right: 0;
        background: linear-gradient(to left, var(--bg), transparent);
    }

    .photo-marquee {
        display: flex;
        gap: 18px;
        width: max-content;
        animation: marquee 70s linear infinite;
        padding: 6px 18px 14px;
    }
    .photo-scroll:hover .photo-marquee { animation-play-state: paused; }

    @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
    }

    /* plain cream photo cards — bordered with a soft ink line, no fill */
    .photo-card {
        flex: 0 0 220px;
        background: var(--bg);
        border: 1px solid var(--faint);
        padding: 8px 8px 0;
        display: flex;
        flex-direction: column;
        transition: transform 0.25s ease, border-color 0.25s ease;
    }
    .photo-card:hover {
        transform: translateY(-2px);
        border-color: var(--border);
    }
    .photo-frame {
        position: relative;
        overflow: hidden;
        background: rgba(26, 26, 26, 0.06);
    }
    .photo-img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        display: block;
    }
    .photo-caption {
        font-family: var(--font-mono);
        font-size: 12.5px;
        color: var(--ink);
        padding: 9px 2px 11px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @media (max-width: 720px) {
        .globe-hud, .globe-legend { font-size: 10.5px; padding: 6px 8px; }
        .photo-card { flex-basis: 168px; padding: 8px 8px 0; }
        .photo-caption { font-size: 11.5px; padding: 8px 2px 10px; }
        .photo-marquee { gap: 14px; }
    }

    @media (prefers-reduced-motion: reduce) {
        .photo-marquee { animation: none; }
    }
</style>

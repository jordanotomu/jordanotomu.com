---
import RandomLayout from "~/layouts/RandomLayout.astro";

// Replace these with the real list whenever you want. Links are optional.
// Keep the list short — this is a shoutout wall, not a phonebook.
const friends: Array<{ name: string; note?: string; href?: string }> = [
    { name: "TODO: friend one", note: "cooks every hackathon", href: "https://linkedin.com/" },
    { name: "TODO: friend two", note: "my go-to design gut-check" },
    { name: "TODO: friend three", note: "memecoin partner in crime" },
    { name: "TODO: friend four", note: "spotted me my first terminal" },
    { name: "TODO: friend five", note: "trenching history docs w/ me" },
    { name: "TODO: friend six", note: "always down for a late-night walk" },
];
---

<RandomLayout
    slug="friends"
    title="Jordan Otomu · random / friends"
    description="People who make the work worth showing up for."
>
    <h2>cool friends</h2>

    <p class="note">
        the people who sharpen me. if your name is here, you either caught me at
        3am debugging or made me laugh in a group chat recently. TODO: swap
        names + notes — or point me to your linkedin and i'll hyperlink.
    </p>

    <ul class="friend-list">
        {friends.map((f) => (
            <li class="friend-row">
                <span class="friend-bullet">•</span>
                {f.href ? (
                    <a class="friend-name" href={f.href} target="_blank" rel="noopener noreferrer">{f.name}</a>
                ) : (
                    <span class="friend-name">{f.name}</span>
                )}
                {f.note && <span class="friend-note">— {f.note}</span>}
            </li>
        ))}
    </ul>
</RandomLayout>

<style>
    .friend-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 6px 2px;
    }
    .friend-row {
        display: flex;
        gap: 8px;
        font-family: var(--font-mono);
        font-size: 14px;
        line-height: 1.5;
        flex-wrap: wrap;
    }
    .friend-bullet { color: var(--muted); }
    .friend-name {
        font-weight: 600;
        color: var(--ink);
    }
    a.friend-name {
        text-decoration: underline;
        text-decoration-color: var(--faint);
        text-underline-offset: 2px;
    }
    a.friend-name:hover {
        text-decoration-color: var(--ink);
    }
    .friend-note { color: var(--muted); }
</style>

---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PathBar from "~/components/PathBar.astro";
import RandomTabs from "~/components/RandomTabs.astro";
---

<BaseLayout
    title="Jordan Otomu · random"
    description="Travel, music, wins, lore, toolbox, and links. The less serious half of jordanotomu.com."
>
    <PathBar segments={[{ label: "random" }]} />

    <fieldset class="box">
        <legend><i>cat ~/random.md</i></legend>

        <div class="motto">
            <div class="motto-label">my life motto</div>
            <div class="motto-text"><i>"do the thing badly before you do it well."</i></div>
        </div>

        <RandomTabs />
    </fieldset>
</BaseLayout>

<style>
    .motto {
        padding-bottom: 16px;
        margin-bottom: 18px;
        border-bottom: 1px solid var(--faint);
    }
    .motto-label {
        font-family: var(--font-mono);
        font-size: 12.5px;
        color: var(--muted);
        margin-bottom: 4px;
    }
    .motto-text {
        font-size: 17px;
        font-family: var(--font-mono);
    }
</style>

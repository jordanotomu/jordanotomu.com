---
interface Props {
    active?: string;
}

const { active } = Astro.props;

const tabs = [
    { slug: "travel", title: "Travel" },
    { slug: "music", title: "Music" },
    { slug: "wins", title: "Wins" },
    { slug: "lore", title: "Lore" },
    { slug: "toolbox", title: "Toolbox" },
    { slug: "links", title: "Links" },
];
---

<nav class="random-tabs" aria-label="random sub-pages">
    {tabs.map((t) => (
        <a
            class={`random-tab ${t.slug === active ? "is-active" : ""}`}
            href={`/random/${t.slug}`}
            aria-current={t.slug === active ? "page" : undefined}
        >
            {t.title}
        </a>
    ))}
</nav>

<style>
    .random-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }
    .random-tab {
        flex: 1 1 0;
        min-width: 110px;
        text-align: center;
        padding: 12px 16px;
        border: 1px solid var(--border);
        color: var(--ink);
        text-decoration: none;
        font-weight: 700;
        font-size: 15px;
        background: var(--bg);
        transition: background 0.15s ease, transform 0.15s ease;
    }
    .random-tab:hover {
        background: var(--faint);
        text-decoration: none;
        transform: translateY(-1px);
    }
    .random-tab.is-active {
        background: var(--ink);
        color: var(--bg);
        border-color: var(--ink);
    }

    @media (max-width: 640px) {
        .random-tab { flex-basis: calc(33.33% - 10px); font-size: 13px; padding: 10px 8px; }
    }
</style>

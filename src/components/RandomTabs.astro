---
interface Props {
    active?: string;
}

const { active } = Astro.props;

const tabs = [
    { slug: "travel", title: "Travel" },
    { slug: "music", title: "Music" },
    { slug: "wins", title: "Wins" },
    { slug: "lore", title: "Lore" },
    { slug: "toolbox", title: "Toolbox" },
    { slug: "links", title: "Links" },
];
---

<nav class="random-tabs" aria-label="random sub-pages">
    {tabs.map((t) => (
        <a
            class={`random-tab ${t.slug === active ? "is-active" : ""}`}
            href={`/random/${t.slug}`}
            aria-current={t.slug === active ? "page" : undefined}
        >
            {t.title}
        </a>
    ))}
</nav>

<style>
    /* "stamp" tabs — cream background with a hard offset shadow + ink
       outline. Hover inverts to ink-on-cream. Active "presses" the tab
       into the shadow space (translate + drop shadow). */
    .random-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 14px 16px;
        padding-right: 6px;
        padding-bottom: 6px;
    }
    .random-tab {
        flex: 1 1 0;
        min-width: 120px;
        text-align: center;
        padding: 13px 18px;
        border: 1px solid var(--ink);
        color: var(--ink);
        text-decoration: none;
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 15px;
        background: var(--bg);
        box-shadow: 3px 3px 0 1px rgba(26, 26, 26, 0.42);
        transition:
            background 0.15s ease,
            color 0.15s ease,
            box-shadow 0.12s ease,
            transform 0.12s ease;
    }
    .random-tab:hover {
        text-decoration: none;
        background: var(--ink);
        color: var(--bg);
        transform: translate(1px, 1px);
        box-shadow: 2px 2px 0 1px rgba(26, 26, 26, 0.42);
    }
    .random-tab:active,
    .random-tab.is-active {
        background: var(--ink);
        color: var(--bg);
        transform: translate(3px, 3px);
        box-shadow: 0 0 0 1px rgba(26, 26, 26, 0.42);
    }

    /* dark mode — flip the shadow to a faint cream so it stays visible */
    [data-theme="dark"] .random-tab {
        box-shadow: 3px 3px 0 1px rgba(243, 241, 231, 0.55);
    }
    [data-theme="dark"] .random-tab:hover {
        box-shadow: 2px 2px 0 1px rgba(243, 241, 231, 0.55);
    }
    [data-theme="dark"] .random-tab.is-active,
    [data-theme="dark"] .random-tab:active {
        box-shadow: 0 0 0 1px rgba(243, 241, 231, 0.55);
    }

    @media (max-width: 640px) {
        .random-tabs { gap: 12px 14px; }
        .random-tab { flex-basis: calc(50% - 14px); font-size: 13.5px; padding: 12px 12px; }
    }
</style>

---
interface Props {
    active?: string;
}

const { active } = Astro.props;

const tabs = [
    { slug: "travel", title: "Travel" },
    { slug: "music", title: "Music" },
    { slug: "wins", title: "Wins" },
    { slug: "lore", title: "Lore" },
    { slug: "toolbox", title: "Toolbox" },
    { slug: "links", title: "Links" },
];
---

<nav class="random-tabs" aria-label="random sub-pages">
    {tabs.map((t) => (
        <a
            class={`random-tab ${t.slug === active ? "is-active" : ""}`}
            href={`/random/${t.slug}`}
            aria-current={t.slug === active ? "page" : undefined}
        >
            {t.title}
        </a>
    ))}
</nav>

<style>
    .random-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }
    .random-tab {
        flex: 1 1 0;
        min-width: 120px;
        text-align: center;
        padding: 14px 18px;
        border: 1px solid var(--tile-border);
        color: var(--ink);
        text-decoration: none;
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 15px;
        background: var(--tile);
        box-shadow: var(--tile-shadow);
        transition:
            background 0.18s ease,
            box-shadow 0.18s ease,
            transform 0.18s ease,
            border-color 0.18s ease;
    }
    .random-tab:hover {
        text-decoration: none;
        transform: translateY(-2px);
        box-shadow: var(--tile-shadow-lift);
        border-color: rgba(26, 26, 26, 0.30);
    }
    .random-tab.is-active {
        background: var(--ink);
        color: var(--bg);
        border-color: var(--ink);
    }

    @media (max-width: 640px) {
        .random-tabs { gap: 10px; }
        .random-tab { flex-basis: calc(33.33% - 10px); font-size: 13px; padding: 12px 10px; }
    }
</style>
